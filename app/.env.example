# Firebase web config — copy this file to `.env` and fill in your project's values.
# Firebase Console -> Project settings (gear) -> General -> Your apps -> Web app
# -> "SDK setup and configuration".
#
# NOTE: these are PUBLIC identifiers, not secrets. They ship in the client bundle
# by design; access is controlled by Firebase Auth + Firestore security rules,
# not by keeping these values hidden.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
